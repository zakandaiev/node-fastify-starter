{
  "#example": {
    "health": "healthy",
    "mysqlStatus": "ready",
    "redisStatus": "ready",
    "requestDate": "2001-01-01T01:01:01.000Z"
  },
  "health": {
    "type": "string",
    "enum": [
      "healthy"
    ],
    "description": "App status"
  },
  "mysqlStatus": {
    "type": "string",
    "enum": [
      "uninstalled",
      "ready"
    ],
    "description": "MySQL status"
  },
  "redisStatus": {
    "type": "string",
    "enum": [
      "uninstalled",
      "wait",
      "reconnecting",
      "connecting",
      "connect",
      "ready",
      "close",
      "end"
    ],
    "description": "Redis status"
  },
  "requestDate": {
    "type": "string",
    "format": "date-time",
    "description": "Request date"
  }
}
